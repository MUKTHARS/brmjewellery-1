# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/brm_jewellery?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Nodemailer (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="BRM Jewellery <noreply@brmjewellery.co.uk>"

# Storage (Local Multer)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Metals API
METALS_API_KEY=your_metals_api_key
METALS_API_BASE_URL=https://metals-api.com/api

# Shipping
ROYAL_MAIL_API_KEY=your_royal_mail_api_key
ROYAL_MAIL_BASE_URL=https://api.royalmail.com
DHL_API_KEY=your_dhl_api_key
DHL_API_SECRET=your_dhl_api_secret
DHL_BASE_URL=https://api.dhl.com
FEDEX_API_KEY=your_fedex_api_key
FEDEX_API_SECRET=your_fedex_api_secret
FEDEX_ACCOUNT_NUMBER=your_account_number
FEDEX_BASE_URL=https://apis.fedex.com

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:3000

# Admin (seed)
ADMIN_EMAIL=admin@brmjewellery.co.uk
ADMIN_PASSWORD=Admin@BRM2024!

